SECRET_KEY=change-me-to-random-string
PASSWORD_HASH=                    # run: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
ANTHROPIC_API_KEY=sk-ant-...

# SMTP (optional — for auto-send)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="SecDigest <you@gmail.com>"

# Tuning
FETCH_TIME=07:00           # 24h local time for daily auto-fetch
HN_MIN_SCORE=50            # minimum HN points to consider
MAX_ARTICLES=15            # articles per newsletter

# Public landing / subscribe site (optional). When enabled, runs a second
# uvicorn instance on PUBLIC_PORT alongside the admin on 8080.
PUBLIC_SITE_ENABLED=0
PUBLIC_HOST=0.0.0.0
PUBLIC_PORT=8000
PUBLIC_BASE_URL=           # e.g. https://secdigest.example.com — used in confirm + unsub links

# TLS — uvicorn serves HTTPS directly using the cert pair below.
# Defaults to ON. Disable (TLS_ENABLED=0) for dev or when nginx terminates TLS in front.
# When ON you MUST point at certs — either via TLS_DOMAIN (uses the standard
# Let's Encrypt layout at /etc/letsencrypt/live/<domain>/{fullchain,privkey}.pem)
# or via explicit TLS_CERTFILE + TLS_KEYFILE paths. Run certbot yourself before
# turning this on; the app does not generate certs.
TLS_ENABLED=1
TLS_DOMAIN=                # e.g. secdigest.example.com — auto-resolves to letsencrypt paths
TLS_CERTFILE=              # explicit override; takes priority over TLS_DOMAIN
TLS_KEYFILE=
